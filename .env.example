# ── AI / Gemini ────────────────────────────────────────────────────────────────
# Required for the /roast endpoint to call Google Gemini.
# Without this key the endpoint returns a canned mock response.
GEMINI_API_KEY=your-gemini-api-key-here

# ── Stripe (optional — not yet implemented) ────────────────────────────────────
# Set these when integrating Stripe checkout flows.
STRIPE_API_KEY=sk_test_your-stripe-test-key-here
STRIPE_PRICE_FREE=price_your-free-tier-price-id
STRIPE_PRICE_TEMPLATE=price_your-template-price-id
STRIPE_PRICE_SAAS=price_your-saas-price-id
STRIPE_SUCCESS_URL=https://yourproformasucks.com/success
STRIPE_CANCEL_URL=https://yourproformasucks.com/cancel
